<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft portal halo -->
    <path
        android:pathData="M16,54 a38,38 0 1,0 76,0 a38,38 0 1,0 -76,0 Z"
        android:fillColor="#3397CE4C" />

    <!-- Portal disc -->
    <path android:pathData="M23,54 a31,31 0 1,0 62,0 a31,31 0 1,0 -62,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="52"
                android:gradientRadius="33">
                <item android:offset="0.0" android:color="#FFE9FFC0" />
                <item android:offset="0.35" android:color="#FFB6E86F" />
                <item android:offset="0.7" android:color="#FF6FB83E" />
                <item android:offset="1.0" android:color="#FF2E6B1E" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Swirl -->
    <path
        android:pathData="M54,32 C70,36 74,56 58,64 C48,69 42,58 51,52"
        android:strokeColor="#E6F3FFD0"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Bright core -->
    <path
        android:pathData="M49,54 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 Z"
        android:fillColor="#FFF4FFE0" />
</vector>
